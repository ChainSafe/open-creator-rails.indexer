{
  "name": "ocr-indexer",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "pnpm install && pnpm contracts:build && pnpm sync",
    "dev": "ponder dev",
    "dev:local": "bash scripts/dev-local.sh",
    "start": "ponder start",
    "db": "ponder db",
    "codegen": "ponder codegen",
    "serve": "ponder serve",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc",
    "contracts:build": "cd open-creator-rails && forge build",
    "sync": "pnpm contracts:build && node scripts/sync-abis.js",
    "sync:deployments": "node scripts/sync-deployments.js",
    "test": "vitest run"
  },
  "dependencies": {
    "abitype": "^1.2.4",
    "graphql": "^16.14.0",
    "graphql-yoga": "^5.21.0",
    "hono": "^4.12.23",
    "ponder": "^0.16.6",
    "viem": "^2.51.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.54.0",
    "eslint-config-ponder": "^0.16.6",
    "typescript": "^5.3.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.14"
  },
  "packageManager": "pnpm@10.32.0"
}