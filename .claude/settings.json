{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git fetch *)",
      "Bash(git tag *)",
      "Bash(git remote *)",
      "Bash(git config --get *)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm sync *)",
      "Bash(pnpm sync:deployments *)",
      "Bash(pnpm codegen *)",
      "Bash(pnpm contracts:build *)",
      "Bash(cast keccak *)",
      "Bash(cast call *)",
      "Bash(cast chain-id *)",
      "Bash(cast wallet *)",
      "Bash(cast abi-encode *)",
      "Bash(cast rpc *)",
      "Bash(forge build *)",
      "Bash(node scripts/sync-abis.js *)",
      "Bash(node scripts/sync-deployments.js *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(find *)"
    ]
  },
  "env": {
    "PATH": "$HOME/.foundry/bin:$PATH"
  }
}
